{
  "app": {
    "dimension": {
      "component": {
        "radius": {
          "round": {
            "$value": "9999px",
            "$type": "dimension"
          },
          "compact": {
            "xs": {
              "$value": "{config.dimension.radius.base} * 2.5",
              "$type": "dimension"
            },
            "sm": {
              "$value": "{config.dimension.radius.base} * 3",
              "$type": "dimension"
            },
            "md": {
              "$value": "{config.dimension.radius.base} * 3.5",
              "$type": "dimension"
            },
            "lg": {
              "$value": "{config.dimension.radius.base} * 4",
              "$type": "dimension"
            },
            "xl": {
              "$value": "{config.dimension.radius.base} * 4.5",
              "$type": "dimension"
            }
          },
          "default": {
            "2xs": {
              "$value": "{config.dimension.radius.base} * 5",
              "$type": "dimension"
            },
            "xs": {
              "$value": "{config.dimension.radius.base} * 5.5",
              "$type": "dimension"
            },
            "sm": {
              "$value": "{config.dimension.radius.base} * 6",
              "$type": "dimension"
            },
            "md": {
              "$value": "{config.dimension.radius.base} * 6.5",
              "$type": "dimension"
            },
            "lg": {
              "$value": "{config.dimension.radius.base} * 7",
              "$type": "dimension"
            },
            "xl": {
              "$value": "{config.dimension.radius.base} * 7.5",
              "$type": "dimension"
            },
            "2xl": {
              "$value": "{config.dimension.radius.base} * 8",
              "$type": "dimension"
            }
          }
        }
      }
    }
  }
}
